{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(node)",
      "Bash(node *)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "PowerShell(npm install*)",
      "PowerShell(npm run dev*)",
      "PowerShell(npm run build*)",
      "PowerShell(node)",
      "PowerShell(node *)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r *)",
      "Bash(git clean -fd*)",
      "Bash(find * -delete*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "PowerShell(Remove-Item -Recurse*)",
      "PowerShell(Remove-Item * -Recurse*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)"
    ]
  }
}
